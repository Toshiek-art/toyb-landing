---
import ConsentBanner from "../components/ConsentBanner.astro";
import Footer from "../components/Footer.astro";
import Navbar from "../components/Navbar.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  lang?: "en" | "it";
  robots?: string;
  enableConsentBanner?: boolean;
  analyticsId?: string;
}

const {
  title = "toyb | Build universes. Break complexity.",
  description = "Toyb is a modular worldbuilding engine for creators who think in systems.",
  canonical,
  ogImage = "/images/assets/toyb-social-cover.png",
  lang = "en",
  robots = "index,follow",
  enableConsentBanner = true,
  analyticsId = "G-6ZD3YD2STD",
} = Astro.props;

const siteOrigin = Astro.site?.toString() ?? "https://toyb.space/";
const canonicalUrl =
  canonical ?? new URL(Astro.url.pathname, siteOrigin).toString();
const ogImageUrl = new URL(ogImage, siteOrigin).toString();
const defaultOgImage = ogImage === "/images/assets/toyb-social-cover.png";
const ogImageWidth = defaultOgImage ? "851" : undefined;
const ogImageHeight = defaultOgImage ? "315" : undefined;
const ogImageAlt = "Toyb social cover";

const softwareApplicationLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "Toyb",
  applicationCategory: "MultimediaApplication",
  operatingSystem: "Web",
  url: "https://toyb.space/",
  description,
};

---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="theme-color" content="#0b0f14" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="toyb" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    {ogImageWidth && <meta property="og:image:width" content={ogImageWidth} />}
    {ogImageHeight && (
      <meta property="og:image:height" content={ogImageHeight} />
    )}
    <meta property="og:image:alt" content={ogImageAlt} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(softwareApplicationLd)}
    />

    <link rel="icon" href="/icons/app/favicon.ico" sizes="any" />
    <link
      rel="icon"
      type="image/png"
      sizes="512x512"
      href="/icons/app/favicon-512x512.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="/icons/app/favicon-32x32.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href="/icons/app/favicon-16x16.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/icons/app/apple-touch-icon.png"
    />
    <link rel="manifest" href="/site.webmanifest" />
    <title>{title}</title>
  </head>

  <body class="theme-toyb">
    <a class="skip-link" href="#main-content">Skip to content</a>
    <header class="site-header">
      <Navbar />
    </header>

    <main id="main-content" class="site-main layout-shell" tabindex="-1">
      <slot />
    </main>

    <Footer />
    {enableConsentBanner && (
      <ConsentBanner analyticsId={analyticsId} policyHref="/privacy" />
    )}

    <script>
      import { track } from "../lib/analytics";

      const reducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;
      const revealTargets = document.querySelectorAll("[data-reveal]");

      if (!reducedMotion && "IntersectionObserver" in window) {
        document.documentElement.classList.add("reveal-enabled");
        const observer = new IntersectionObserver(
          (entries, source) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              entry.target.classList.add("is-visible");
              source.unobserve(entry.target);
            });
          },
          { threshold: 0.2 },
        );

        revealTargets.forEach((target) => observer.observe(target));
      } else {
        revealTargets.forEach((target) => target.classList.add("is-visible"));
      }

      document.querySelectorAll("[data-track]").forEach((element) => {
        element.addEventListener("click", () => {
          const eventName = element.getAttribute("data-track");
          if (!eventName) return;
          track(eventName, { path: window.location.pathname, beta: true });
        });
      });
    </script>
  </body>
</html>
